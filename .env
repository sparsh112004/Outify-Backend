# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC
DJANGO_LOG_LEVEL=INFO

# Database (MYSql)
DB_HOST=localhost
DB_PORT=3306
DB_USER=outing_user
DB_PASSWORD=StrongPassword123!
